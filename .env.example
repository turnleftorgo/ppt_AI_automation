# ============================================================
# Dify API 配置
# ============================================================
DIFY_API_KEY=your_dify_api_key_here
DIFY_BASE_URL=http://your-dify-host:3001/v1

# ============================================================
# Dify 知识库 RAG 配置（可选 - 用于检索增强生成）
# 需要一个带知识库的 Dify App
# ============================================================
RAG_API_KEY=your_rag_app_api_key_here
RAG_DIFY_BASE_URL=http://your-dify-host:3001/v1

# ============================================================
# SiliconFlow API 配置（可选 - 仅用于 RAGAS 测试评估）
# ============================================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2
